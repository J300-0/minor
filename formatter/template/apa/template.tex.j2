\documentclass[12pt,a4paper]{article}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage[margin=1in]{geometry}
\usepackage{times}
\usepackage{amsmath,amssymb}
\usepackage{graphicx}
\usepackage[export]{adjustbox}
\usepackage{booktabs}
\usepackage{multirow}
\usepackage{array}
\usepackage{tabularx}
\usepackage{setspace}
\usepackage{url}
\usepackage{hyperref}
\doublespacing

\begin{document}

\begin{titlepage}
\centering
\vspace*{2cm}
{\LARGE \textbf{\VAR{title | e}}\par}
\vspace{1.5cm}
%% for author in authors
{\large \VAR{author.name | e}\par}
%% if author.department
{\normalsize \VAR{author.department | e}\par}
%% endif
%% if author.organization
{\normalsize \VAR{author.organization | e}\par}
%% endif
%% if author.city
{\normalsize \VAR{author.city | e}\par}
%% endif
%% if author.email
{\normalsize \texttt{\VAR{author.email | e}}\par}
%% endif
%% endfor
\vfill
\end{titlepage}

%% if abstract
\begin{abstract}
\VAR{abstract | paras}
%% if keywords
\textbf{Keywords:} \VAR{keywords | join(', ') | e}
%% endif
\end{abstract}
%% endif

%% for section in sections
\VAR{section.depth | section_cmd}{\VAR{section.heading | e}}

%% for block in section.content_blocks
%% if block.type == "text"
\VAR{block.content}

%% elif block.type == "raw_latex"
\VAR{block.content}

%% elif block.type == "equation"
\smallskip
%% if block.latex
%% if block.equation_number
\begin{equation*}\tag{\VAR{block.equation_number}}
\VAR{block.latex}
\end{equation*}
%% else
\begin{equation*}
\VAR{block.latex}
\end{equation*}
%% endif
%% elif block.image_path
%% if block.equation_number
\noindent\hfill\includegraphics[max width=0.85\columnwidth, max height=4cm]{\VAR{block.image_path}}\hfill(\VAR{block.equation_number})\hspace*{0pt}
%% else
\begin{center}
\includegraphics[max width=0.85\columnwidth, max height=4cm]{\VAR{block.image_path}}
\end{center}
%% endif
%% endif
\smallskip\noindent
%% endif
%% endfor

%% for table in section.tables
\VAR{table | render_table}
%% endfor

%% for figure in section.figures
\begin{figure}[htbp]
\centering
\includegraphics[max width=\columnwidth, max height=0.4\textheight]{\VAR{figure.image_path}}
%% if figure.caption
\caption{\VAR{figure.caption | e}}
%% endif
%% if figure.label
\label{\VAR{figure.label}}
%% endif
\end{figure}
%% endfor

%% endfor

%% if references
\section*{References}
\begin{enumerate}
%% for ref in references
\item \VAR{ref.text | e}
%% endfor
\end{enumerate}
%% endif

%% if formula_blocks
\smallskip
%% for fb in formula_blocks
%% if fb.latex
%% if fb.equation_number
\begin{equation*}\tag{\VAR{fb.equation_number}}
\VAR{fb.latex}
\end{equation*}
%% else
\begin{equation*}
\VAR{fb.latex}
\end{equation*}
%% endif
%% elif fb.image_path
%% if fb.equation_number
\noindent\hfill\includegraphics[max width=0.85\columnwidth, max height=4cm]{\VAR{fb.image_path}}\hfill(\VAR{fb.equation_number})\hspace*{0pt}
%% else
\begin{center}
\includegraphics[max width=0.85\columnwidth, max height=4cm]{\VAR{fb.image_path}}
\end{center}
%% endif
%% endif
%% endfor
%% endif

\end{document}
