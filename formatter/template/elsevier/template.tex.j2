\documentclass[preprint,12pt]{elsarticle}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{amsmath,amssymb}
\usepackage{graphicx}
\usepackage{hyperref}
\usepackage{lineno}

\journal{Journal Name}

\begin{document}

\begin{frontmatter}

\title{\VAR{title | e}}

%% for author in authors
%% if author.email
\author{\VAR{author.name | e}\fnref{fn\VAR{loop.index}}}
%% else
\author{\VAR{author.name | e}}
%% endif
%% if author.department or author.organization or author.city
\address{\VAR{[author.department, author.organization, author.city, author.country] | select | map('e') | join(', ')}}
%% endif
%% if author.email
\fntext[fn\VAR{loop.index}]{\VAR{author.email | e}}
%% endif
%% endfor

%% if abstract
\begin{abstract}
\VAR{abstract | paras}
\end{abstract}
%% endif

%% if keywords
\begin{keyword}
\VAR{keywords | map('e') | join(' \\sep ')}
\end{keyword}
%% endif

\end{frontmatter}

%% for section in sections
\VAR{section.depth | section_cmd}{\VAR{section.heading | e}}
\VAR{section.body | paras}

%% for table in section.tables
\VAR{table | render_table}
%% endfor

%% for figure in section.figures
\begin{figure}[htbp]
\centering
\includegraphics[width=\columnwidth]{\VAR{figure.image_path}}
%% if figure.caption
\caption{\VAR{figure.caption | e}}
%% endif
%% if figure.label
\label{\VAR{figure.label}}
%% endif
\end{figure}
%% endfor

%% endfor

%% if references
\begin{thebibliography}{99}
%% for ref in references
\bibitem{ref\VAR{ref.index}}
\VAR{ref.text | e}

%% endfor
\end{thebibliography}
%% endif

\end{document}
