\documentclass[conference]{IEEEtran}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\IEEEoverridecommandlockouts
\usepackage{cite}
\usepackage{amsmath,amssymb,amsfonts}
\usepackage{graphicx}
\usepackage[export]{adjustbox}  % max width/height for includegraphics
\usepackage{textcomp}
\usepackage{xcolor}
\usepackage{hyperref}
\usepackage{booktabs}
\usepackage{multirow}
\usepackage{array}
\usepackage{tabularx}
\usepackage{url}
% placeins removed — \FloatBarrier causes large white gaps in two-column layout
% stfloats removed — not installed on all TeX distributions

\begin{document}

\title{\VAR{title | e}}

%% if authors
%% set col_width = (0.96 / (authors | length)) | round(4)
\author{%
\IEEEoverridecommandlockouts%
%% for author in authors
\begin{minipage}[t]{\VAR{col_width}\textwidth}\centering
{\normalsize\textbf{\VAR{author.name | e}}}\\[2pt]
{\footnotesize \VAR{author.department | e}%
%% if author.organization
\\ \VAR{author.organization | e}%
%% endif
%% if author.city and author.country
\\ \VAR{author.city | e}, \VAR{author.country | e}%
%% elif author.city
\\ \VAR{author.city | e}%
%% elif author.country
\\ \VAR{author.country | e}%
%% endif
%% if author.email
\\ \VAR{author.email | e}%
%% endif
}
\end{minipage}%
%% if not loop.last
\hfill%
%% endif
%% endfor
}
%% endif

\maketitle

%% if abstract
\begin{abstract}
\VAR{abstract | paras}
\end{abstract}
%% endif

%% if keywords
\begin{IEEEkeywords}
\VAR{keywords | join(', ') | e}
\end{IEEEkeywords}
%% endif

%% for section in sections

\VAR{section.depth | section_cmd}{\VAR{section.heading | e}}

%% for block in section.content_blocks
%% if block.type == "text"
\VAR{block.content}

%% elif block.type == "raw_latex"
\VAR{block.content}

%% elif block.type == "equation"
%% if block.latex
\begin{equation}
\VAR{block.latex}
\end{equation}
%% elif block.image_path
\begin{equation}
\vcenter{\hbox{\includegraphics[max width=0.85\columnwidth, max height=4cm]{\VAR{block.image_path}}}}
\end{equation}
%% endif
%% endif
%% endfor

%% for figure in section.figures
%% if figure.image_path
\begin{figure}[!htbp]
\centering
\includegraphics[max width=\columnwidth, max height=0.4\textheight]{\VAR{figure.image_path}}
%% if figure.caption
\caption{\VAR{figure.caption | e}}
%% endif
%% if figure.label
\label{\VAR{figure.label}}
%% endif
\end{figure}
%% endif
%% endfor

%% for table in section.tables
\VAR{table | render_table}
%% endfor

%% endfor

%% if references
\begin{thebibliography}{\VAR{references | length}}
%% for ref in references
\bibitem{ref\VAR{ref.index}}
\VAR{ref.text | e}

%% endfor
\end{thebibliography}
%% endif

\end{document}
