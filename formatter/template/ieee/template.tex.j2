\documentclass[conference]{IEEEtran}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\IEEEoverridecommandlockouts
\usepackage{cite}
\usepackage{amsmath,amssymb,amsfonts}
\usepackage{graphicx}
\usepackage[export]{adjustbox}  % max width/height for includegraphics
\usepackage{textcomp}
\usepackage{xcolor}
\usepackage{hyperref}
\usepackage{booktabs}
\usepackage{multirow}
\usepackage{array}
\usepackage{tabularx}
\usepackage{url}
% placeins removed — \FloatBarrier causes large white gaps in two-column layout
% stfloats removed — not installed on all TeX distributions

\begin{document}

\title{\VAR{title | e}}

%% if authors
\author{
%% for author in authors
  \IEEEauthorblockN{\VAR{author.name | e}}
  \IEEEauthorblockA{
%% if author.department
    \textit{\VAR{author.department | e}}\\
%% endif
%% if author.organization
    \VAR{author.organization | e}\\
%% endif
%% if author.city and author.country
    \VAR{author.city | e}, \VAR{author.country | e}\\
%% elif author.city
    \VAR{author.city | e}\\
%% elif author.country
    \VAR{author.country | e}\\
%% endif
%% if author.email
    \VAR{author.email | e}
%% endif
  }
%% if not loop.last
  \and
%% endif
%% endfor
}
%% endif

\maketitle

%% if abstract
\begin{abstract}
\VAR{abstract | paras}
\end{abstract}
%% endif

%% if keywords
\begin{IEEEkeywords}
\VAR{keywords | join(', ') | e}
\end{IEEEkeywords}
%% endif

%% for section in sections

\VAR{section.depth | section_cmd}{\VAR{section.heading | e}}

%% for block in section.content_blocks
%% if block.type == "text"
\VAR{block.content}

%% elif block.type == "raw_latex"
\VAR{block.content}

%% elif block.type == "equation"
\smallskip
%% if block.latex
%% if block.equation_number
\begin{equation*}\tag{\VAR{block.equation_number}}
\VAR{block.latex}
\end{equation*}
%% else
\begin{equation*}
\VAR{block.latex}
\end{equation*}
%% endif
%% elif block.image_path
%% if block.equation_number
\noindent\hfill\includegraphics[max width=0.85\columnwidth, max height=4cm]{\VAR{block.image_path}}\hfill(\VAR{block.equation_number})\hspace*{0pt}
%% else
\begin{center}
\includegraphics[max width=0.85\columnwidth, max height=4cm]{\VAR{block.image_path}}
\end{center}
%% endif
%% endif
\smallskip\noindent
%% endif
%% endfor

%% for figure in section.figures
%% if figure.image_path
\begin{figure}[!htbp]
\centering
\includegraphics[max width=\columnwidth, max height=0.4\textheight]{\VAR{figure.image_path}}
%% if figure.caption
\caption{\VAR{figure.caption | e}}
%% endif
%% if figure.label
\label{\VAR{figure.label}}
%% endif
\end{figure}
%% endif
%% endfor

%% for table in section.tables
\VAR{table | render_table}
%% endfor

%% endfor

%% if formula_blocks
\smallskip
%% for fb in formula_blocks
%% if fb.latex
%% if fb.equation_number
\begin{equation*}\tag{\VAR{fb.equation_number}}
\VAR{fb.latex}
\end{equation*}
%% else
\begin{equation*}
\VAR{fb.latex}
\end{equation*}
%% endif
%% elif fb.image_path
%% if fb.equation_number
\noindent\hfill\includegraphics[max width=0.85\columnwidth, max height=4cm]{\VAR{fb.image_path}}\hfill(\VAR{fb.equation_number})\hspace*{0pt}
%% else
\begin{center}
\includegraphics[max width=0.85\columnwidth, max height=4cm]{\VAR{fb.image_path}}
\end{center}
%% endif
%% endif
%% endfor
%% endif

%% if references
\begin{thebibliography}{\VAR{references | length}}
%% for ref in references
\bibitem{ref\VAR{ref.index}}
\VAR{ref.text | e}

%% endfor
\end{thebibliography}
%% endif

\end{document}
