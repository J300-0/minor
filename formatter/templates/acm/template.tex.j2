\documentclass[sigconf]{acmart}
\usepackage[utf8]{inputenc}
\usepackage{booktabs}
\begin{document}

\title{\VAR{title | e}}

%% for author in authors
\author{\VAR{author.name | e}}
%% if author.organization
\affiliation{\institution{\VAR{author.organization | e}}}
%% endif
%% if author.email
\email{\VAR{author.email | e}}
%% endif
%% endfor

\begin{abstract}
\VAR{abstract | e}
\end{abstract}

%% if keywords
\keywords{\VAR{keywords | map("e") | join(", ")}}
%% endif

\maketitle

%% for section in sections
\section{\VAR{section.heading | e}}
\VAR{section.body | paras}

%% for table in section.tables
\begin{table}[htbp]
\caption{\VAR{table.caption | e}}
\begin{tabular}{\VAR{"l" + "r" * ([table.headers | length - 1, 0] | max)}}
\toprule
%% if table.headers
\VAR{table.headers | map("e") | join(" & ")} \\
\midrule
%% endif
%% for row in table.rows
\VAR{row | map("e") | join(" & ")} \\
%% endfor
\bottomrule
\end{tabular}
\end{table}
%% endfor

%% endfor

\bibliographystyle{ACM-Reference-Format}
%% if references
\begin{thebibliography}{00}
%% for ref in references
\bibitem{b\VAR{ref.index}} \VAR{ref.text | e}
%% endfor
\end{thebibliography}
%% endif

\end{document}
